# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@finmind.xxxxx.mongodb.net/ironpulse?retryWrites=true&w=majority

# Application Settings
ENV=production
PORT=8080
SERVER_PORT=8080

# Admin Credentials (update from defaults)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ironpulse123

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Logging Level
LOG_LEVEL=INFO

# Database Settings
DB_NAME=ironpulse
DB_COLLECTION_MEMBERS=members
DB_COLLECTION_PAYMENTS=payments

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
JWT_SECRET=your-secret-key-here-min-32-characters

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15
